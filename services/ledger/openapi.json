    "components": {
        "schemas": {
            "CreateGoalRequest": {
                "required": [
                    "goalText",
                    "stakeCents",
                    "charityId",
                    "driveMode",
                    "deadline",
                    "milestones"
                ],
                "type": "object",
                "properties": {
                    "goalText": {
                        "type": "string"
                    },
                    "stakeCents": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "charityId": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "driveMode": {
                        "type": "string"
                    },
                    "deadline": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "milestones": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/CreateMilestone"
                        }
                    }
                }
            },
            "CreateMilestone": {
                "required": [
                    "description",
                    "targetMetric",
                    "dueDate"
                ],
                "type": "object",
                "properties": {
                    "description": {
                        "type": "string"
                    },
                    "targetMetric": {
                        "type": "string"
                    },
                    "dueDate": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "DecisionRequest": {
                "required": [
                    "decision",
                    "idempotencyKey"
                ],
                "type": "object",
                "properties": {
                    "decision": {
                        "type": "string"
                    },
                    "idempotencyKey": {
                        "type": "string"
                    }
                }
            },
            "ProofRequest": {
                "required": [
                    "milestoneId",
                    "claim",
                    "evidenceBase64",
                    "mime",
                    "idempotencyKey"
                ],
                "type": "object",
                "properties": {
                    "milestoneId": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "claim": {
                        "type": "string"
                    },
                    "evidenceBase64": {
                        "type": "string"
                    },
                    "mime": {
                        "type": "string"
                    },
                    "idempotencyKey": {
                        "type": "string"
                    }
                }
            },
            "RefereeDecisionRequest": {
                "required": [
                    "decision",
                    "refereeUserId",
                    "idempotencyKey"
                ],
                "type": "object",
                "properties": {
                    "decision": {
                        "type": "string"
                    },
                    "refereeUserId": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "idempotencyKey": {
                        "type": "string"
                    }
                }
            },
            "SubmitProofRequest": {
                "required": [
                    "claim",
                    "evidenceBase64",
                    "mime",
                    "idempotencyKey"
                ],
                "type": "object",
                "properties": {
                    "claim": {
                        "type": "string"
                    },
