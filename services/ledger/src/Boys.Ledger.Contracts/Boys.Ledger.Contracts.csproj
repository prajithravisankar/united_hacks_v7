<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- gen/ is committed, generated C# (auto-generated) — don't nag about missing XML docs. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Google.Protobuf" Version="3.35.1" />
    <PackageReference Include="Grpc.Net.Client" Version="2.80.0" />
  </ItemGroup>

  <!--
    C# gRPC stubs are pre-generated into gen/ and committed (same pattern as services/engine/gen and
    services/brain/gen). Regenerate with scripts/gen_protos.sh. This replaces build-time Grpc.Tools
    codegen because that tool's bundled arm64 protoc segfaults inside the Docker build; committing the
    output keeps one .proto source of truth AND a reliable container build. gen/*.cs compile via the
    default glob.
  -->

</Project>
