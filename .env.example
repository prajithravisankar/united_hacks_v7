# Copy to `.env` (gitignored) and fill in. docker-compose reads these.
# LOCAL-ONLY dev defaults — the DBs bind to 127.0.0.1. Replace these before any non-loopback exposure.

# SQL Server (mssql 2022, amd64-emulated) — ledger's OLTP store.
# SA password MUST meet complexity: 8+ chars, upper + lower + digit + symbol.
MSSQL_SA_PASSWORD=Boys_Dev_Passw0rd!

# Oracle Free (gvenzl/oracle-free) — brain's OLAP warehouse.
ORACLE_PASSWORD=Boys_Dev_Passw0rd
ORACLE_APP_USER=boys
ORACLE_APP_PASSWORD=Boys_Dev_Passw0rd
